# 安全密钥 - 生产环境必须修改（使用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成）
SECRET_KEY=your-production-secret-key-here

# CORS 允许的域名列表（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://yourdomain.com

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=order_system

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# 是否开启 API 文档（生产环境建议关闭）
ENABLE_DOCS=false

# 上传目录
UPLOAD_DIR=uploads

# 最大文件大小（字节）5MB
MAX_FILE_SIZE=5242880

# 服务器配置
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:5173
